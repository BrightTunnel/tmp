id,
pkey,
pname,
projecttype,
lead,
archived
FROM project
ORDER BY pkey;
3. Workflow Inventory
SQL
Copy code
SELECT
id,
workflowname,
LENGTH(descriptor) AS xml_size
FROM jiraworkflows
ORDER BY xml_size DESC;
Large XML workflows correlate with migration complexity.
4. Workflow → Project Usage
SQL
Copy code
SELECT
p.pkey,
w.workflowname
FROM nodeassociation na
JOIN project p
 ON p.id=na.source_node_id
JOIN workflowscheme ws
 ON ws.id=na.sink_node_id
JOIN workflowschemeentity wse
 ON wse.scheme=ws.id
JOIN jiraworkflows w
 ON w.workflowname=wse.workflow
WHERE na.association_type='ProjectScheme';
5. Script Detection in Workflows
SQL
Copy code
SELECT
workflowname,
CASE
 WHEN descriptor ILIKE '%groovy%' THEN 'groovy'
 WHEN descriptor ILIKE '%scriptrunner%' THEN 'scriptrunner'
 WHEN descriptor ILIKE '%sil%' THEN 'sil'
 WHEN descriptor ILIKE '%jmwe%' THEN 'jmwe'
 ELSE 'unknown'
END AS script_type
FROM jiraworkflows
WHERE descriptor ILIKE '%script%'
 OR descriptor ILIKE '%groovy%';
6. Extract Embedded Groovy Scripts
SQL
Copy code
SELECT
workflowname,
substring(descriptor from '.{0,500}groovy.{0,500}')
FROM jiraworkflows
WHERE descriptor ILIKE '%groovy%';
Often used with ScriptRunner for Jira.
